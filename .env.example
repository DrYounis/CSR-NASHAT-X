# Twitter/X API Credentials
# احصل عليها من: https://developer.twitter.com/en/portal/dashboard

API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
ACCESS_TOKEN=your_access_token_here
ACCESS_TOKEN_SECRET=your_access_token_secret_here
BEARER_TOKEN=your_bearer_token_here

# Cloudflare Worker Configuration
# These are for the Cloudflare Worker proxy (cloudflare_worker.js)

# GitHub API for triggering Actions
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# Anthropic API for AI content generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model version (optional - uses latest if not specified)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Security Configuration
# Comma-separated list of allowed origins for CORS (use * for development only)
ALLOWED_ORIGINS=https://nashattcsr.com,https://www.nashattcsr.com,https://nashat-csr.pages.dev

# API Secret Key for dashboard authentication (generate a secure random string)
API_SECRET_KEY=your_secure_random_key_here_minimum_32_characters

# ملاحظات:
# 1. انسخ هذا الملف وسمّه .env
# 2. ضع المفاتيح الحقيقية بدلاً من النصوص التوضيحية
# 3. لا ترفع ملف .env على GitHub أبداً!
# 4. احفظ API_SECRET_KEY في مكان آمن - ستحتاجه للمصادقة في لوحة التحكم
# 5. ALLOWED_ORIGINS: غيّر النطاقات لتناسب نطاقك الفعلي قبل النشر

# لتوليد مفتاح آمن:
# macOS/Linux: openssl rand -hex 32
# Windows: powershell -Command "New-Object System.Net.WebClient | Select-Object -ExpandProperty DownloadString | Invoke-Expression 'https://www.random.org/cgi-bin/randbyte?n=32&b=h'"
